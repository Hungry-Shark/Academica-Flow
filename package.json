{
  "name": "academica-flow",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:mcp": "tsc --project tsconfig.mcp.json",
    "preview": "vite preview",
    "vercel-build": "vite build",
    "start": "node dist/server.js",
    "test": "jest",
    "test:unit": "jest --testPathPattern=unit",
    "test:integration": "jest --testPathPattern=integration",
    "test:nep-compliance": "jest --testPathPattern=nep-compliance",
    "test:conflict-detection": "jest --testPathPattern=conflict-detection",
    "test:performance": "jest --testPathPattern=performance",
    "test:e2e": "jest --testPathPattern=e2e",
    "test:all": "jest --runInBand",
    "test:deployment": "jest --testPathPattern=deployment",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "test:debug": "jest --detectOpenHandles --forceExit",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:seed": "prisma db seed",
    "db:reset": "prisma migrate reset",
    "db:studio": "prisma studio",
    "deploy": "./deployment/scripts/deploy.sh",
    "backup": "./deployment/scripts/backup.sh backup",
    "backup:recover": "./deployment/scripts/backup.sh recover",
    "backup:list": "./deployment/scripts/backup.sh list",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:build": "docker-compose build",
    "docker:logs": "docker-compose logs -f",
    "docker:restart": "docker-compose restart",
    "docker:clean": "docker-compose down -v --remove-orphans",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit",
    "build:all": "npm run build && npm run build:mcp",
    "clean": "rm -rf dist node_modules/.cache",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@google/genai": "latest",
    "@google/generative-ai": "^0.24.1",
    "@headlessui/react": "^1.7.17",
    "@prisma/client": "^5.7.1",
    "@faker-js/faker": "^8.4.1",
    "chromadb": "^1.7.3",
    "cloudinary": "^2.7.0",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "firebase": "^12.2.1",
    "helmet": "^7.1.0",
    "html2canvas": "^1.4.1",
    "ioredis": "^5.3.2",
    "jspdf": "^2.5.1",
    "jspdf-autotable": "^3.8.2",
    "jsonwebtoken": "^9.0.2",
    "langchain": "^0.1.0",
    "morgan": "^1.10.0",
    "openai": "^4.20.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "redis": "^4.6.12",
    "winston": "^3.11.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@faker-js/faker": "^8.4.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.8",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.11.16",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/supertest": "^2.0.16",
    "autoprefixer": "^10.4.21",
    "eslint": "^8.55.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.2",
    "jest": "^29.7.0",
    "postcss": "^8.5.6",
    "prettier": "^3.1.1",
    "prisma": "^5.7.1",
    "supertest": "^6.3.3",
    "tailwindcss": "^3.4.17",
    "terser": "^5.44.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "vite": "^5.0.12"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": ["<rootDir>/src", "<rootDir>/tests"],
    "testMatch": [
      "**/__tests__/**/*.ts",
      "**/?(*.)+(spec|test).ts"
    ],
    "transform": {
      "^.+\\.ts$": "ts-jest"
    },
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!src/**/*.d.ts",
      "!src/**/*.test.ts",
      "!src/**/*.spec.ts"
    ],
    "coverageDirectory": "coverage",
    "coverageReporters": ["text", "lcov", "html"],
    "setupFilesAfterEnv": ["<rootDir>/tests/setup.ts"],
    "testTimeout": 30000,
    "maxWorkers": 1
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  }
}
